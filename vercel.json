{
  "functions": {
    "app/api/tenders/**": { "maxDuration": 30 },
    "app/api/webhooks/**": { "maxDuration": 10 },
    "app/api/cron/**": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/deadline-reminders",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 4 * * 1"
    }
  ]
}
